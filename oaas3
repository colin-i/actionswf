def stop_server():
	pid=int(server_pid)
	try:
		os.kill(pid, signal.SIGTERM) #async
	except ProcessLookupError:
		return
	try:
		os.kill(pid, 0)  # signal 0 = just checks if it's alive
	except ProcessLookupError:
		return
	time.sleep(1)
	try:
		os.kill(pid, 0)
	except ProcessLookupError:
		return
	try:
		os.kill(pid, signal.SIGKILL)
	except ProcessLookupError:
		return
def exiting():
	stop_server()
	exit(1)

