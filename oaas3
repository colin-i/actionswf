	import filecmp
	#first is the format
	for i, f in enumerate(files):
		orig = Path(f)
		origf = Path(files_f[i])
		not_ex=not origf.exists()
		if not_ex:
			origf.parent.mkdir(parents=True, exist_ok=True)
		if texts[i]:
			if not_ex or origf.read_text() != texts[i]:
				with open(origf,"w") as file:
					file.write(texts[i])
		elif not_ex or not filecmp.cmp(orig, origf, shallow=False):
			shutil.copy(orig, origf)

	import difflib

	for i, f in enumerate(files_f):
		origf = Path(f)
		mirror = Path(files_mirror[i])
		src = Path(files_src[i])
		if not mirror.exists():
			# create parent folders
			mirror.parent.mkdir(parents=True, exist_ok=True)
			src.parent.mkdir(parents=True, exist_ok=True)

			# create mirror copy
			shutil.copy(origf, mirror) # or copy2: Identical to copy() except that copy2() also attempts to preserve file metadata.

			# create src copy
			shutil.copy(origf, src)
		else:
			old = mirror.read_text().splitlines(keepends=True)
			new = origf.read_text().splitlines(keepends=True)
			out = src.read_text().splitlines(keepends=True)
			matcher = difflib.SequenceMatcher(None, old, new)
			offset = 0
			#        old     new
			for tag, i1, i2, j1, j2 in matcher.get_opcodes():
				if tag == "equal":
					continue
				print(tag)
				print("old:", old[i1:i2])
				print("new:", new[j1:j2])

				i1 += offset
				i2 += offset
				if tag == "insert":
					out[i1:i1] = new[j1:j2]
					offset += (j2 - j1)
					continue
				if tag == "replace":
					out[i1:i2] = new[j1:j2]
					offset += (j2 - j1) - (i2 - i1)
					continue
				if tag == "delete":
					del out[i1:i2]
					offset -= (i2 - i1)
					continue
				print('?')
				exit(1)
			src.write_text(''.join(out))#os.linesep
			mirror.write_text(''.join(new))

