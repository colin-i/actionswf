
format elfobj64

const a_page_size=0x1000
#multithread unsafe
charx a_page#a_page_size

einclude "../include/common.h" "../include/common.oh"
Const c_low=0x63
Const e_low=0x65
Const h_low=0x68
Const i_low=0x69
Const o_low=0x6F
Const w_low=0x77

importx "snprintf" snprintf
importx "strstr" strstr

^import "replace" replace 5
^import "spcafter" spcafter 1
^import "spcfull" spcfull 1
import "translated" translated
import "untranslated" untranslated

function translate_two(ss start,ss oa)
	ss ?chr;set chr oa#
	if chr=(s_low)
		inc oa
		whiletrue
			if oa#!=(Space)
				if oa#!=(HorizontalTab)
					break
				end
			end
			ss s;set s translate_search(start,oa)
			if s!=oa
				return s
			end
			break
		end
		dec oa
	elseif chr=(e_low)
		inc oa
		if oa#=(Nullchar)
			ss str="()"
			ss p;set p strstr(start,str)
			if p!=(NULL)
				set p# (Nullchar)
				ss pp=2;add pp p
				sd ?n;set n snprintf(#globalt.a_page,(a_page_size),"%s(e)%s",start,pp)
				#set p# '('
				if n>0
					if n<(a_page_size)
						call translated("Event")
						return #globalt.a_page
					end
				end
			end
		end
		dec oa
	end
	return oa
end

function translate_one(ss oa,ss start)
	sd ?len
	ss ?chr;set chr oa#
	ss cursor
	if chr=(a_low)
		inc oa
		whiletrue
			if oa#!=(Space)
				if oa#!=(HorizontalTab)
					break
				end
			end
			inc oa

			ss o_a;set o_a spcfull(oa) #this is for safety in case there are more whites, they will be preserved
			set cursor spcafter(o_a)
			ss pointer;ss ext
			ss ?reminder
			if cursor!=o_a
				set ext " extends "
				set pointer spcfull(cursor)
				set reminder cursor#;set cursor# (Nullchar)
			else
				set ext ""
				set pointer ext
				set reminder (Nullchar)
			end
			set len snprintf(#globalt.a_page,(a_page_size),"class %s%s%s{",oa,ext,pointer)
			if len>0
				if len<(a_page_size)
					call translated("Class")
					return #globalt.a_page
				end
			end
			set cursor# reminder

			dec oa
			break
		end
		dec oa
	elseif chr=(c_low)
		inc oa
		whiletrue
			if oa#!=(Space)
				if oa#!=(HorizontalTab)
					break
				end
			end
			inc oa
			set len snprintf(#globalt.a_page,(a_page_size),"//%s",oa)
			if len>0
				if len<(a_page_size)
					call translated("Comment")
					return #globalt.a_page
				end
			end
			dec oa
			break
		end
		dec oa
	elseif chr=(i_low)
		inc oa
		whiletrue
			if oa#!=(Space)
				if oa#!=(HorizontalTab)
					break
				end
			end
			vstr importstr="import"
			set len snprintf(#globalt.a_page,(a_page_size),"%s%s;",importstr,oa)
			if len>0
				if len<(a_page_size)
					call translated("Import")
					return #globalt.a_page
				end
			end
			break
		end
		dec oa
	elseif chr=(o_low)
		inc oa
		whiletrue
			if oa#!=(Space)
				if oa#!=(HorizontalTab)
					break
				end
			end
			inc oa
			set chr oa#
			if chr=(c_low)
				set cursor translate_on(oa,"CLICK",start)
			elseif chr=(i_low)
				set cursor translate_on(oa,"MOUSE_OVER",start)
			elseif chr=(o_low)
				set cursor translate_on(oa,"MOUSE_OUT",start)
			end
			if cursor!=oa
				call translated("On")
				return cursor
			end
			dec oa
			break
		end
		dec oa
	elseif chr=(Nullchar)
		call translated("Blank")
		return oa
	else
		set cursor spcfull(oa)
		if cursor#=(Closingbrace)
			inc cursor
			if cursor#=(Nullchar)
				call translated("Closing")
				return oa
			end
		end
	end
	call untranslated(oa)
	return oa
end

function translate_search(ss start,ss oa)
	ss cursor;set cursor oa
	inc cursor
	ss str
	while cursor#!=(Nullchar)
		if cursor#=(_)
			ss src;set src start
			ss dest;set dest start
			whiletrue
				if src#=(Nullchar)
					break
				end
				if src#!=(_)
					set dest# src#
					inc dest
				end
				inc src
			end
			if dest!=src
				set dest# (Nullchar)
				inc cursor
				continue
			end
		elseif cursor#=(w_low)
			set str replace(start,"Stage.w","stage.stageW",#globalt.a_page,(a_page_size))
			if str!=start
				set start str
				inc cursor
				continue
			end
		elseif cursor#=(h_low)
			set str replace(start,"Stage.h","stage.stageH",#globalt.a_page,(a_page_size))
			if str!=start
				set start str
				inc cursor
				continue
			end
		end
		return oa
	end
	call translated("Search")
	return start
end

function translate_on(ss oa,ss ev,ss start)
	ss cursor;set cursor spcfull(start)
	set cursor# (Nullchar)

	inc oa
	sd ?n;set n snprintf(#globalt.a_page,(a_page_size),"%saddEventListener(MouseEvent.%s,%s);",start,ev,oa)
	if n>0
		if n<(a_page_size)
			return #globalt.a_page
		end
	end
	dec oa
	return oa
end

entryraw globalt()
