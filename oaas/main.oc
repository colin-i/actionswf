
format elfobj64

^import "translate" translate 2
^import "translate_normal" translate_normal 1

^import "spc" spc 1

functionx line(ss oa)
	set oa spc(oa)
	callret translate_normal(oa)
end

functionx startline(ss start,ss oa)
	set oa spc(oa)

	#at this function first can be syntax dependent of start string
	ss result
	set result translate(start,oa)
	if result!=oa
		return result
	end

	#or normal line
	callret translate_normal(oa)
end
