
format elfobj64

function spc(ss a)
	whiletrue
		#if a#=0x9			inc a		else
		if a#=0x20
			inc a
		else
			return a
		end
	end
end
functionx line(ss oa)
	#remove "text" 'text'
	#a . af . function a() -> function a(e) , find ()
	#r . r_x _x -> x
	#x next is untranslated
	set oa spc(oa)
	return oa
end
